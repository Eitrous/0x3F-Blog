---
import { getCollection } from "astro:content";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

const posts = await getCollection("blog", ({ data }) => !data.draft);

posts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<!doctype html>
<html lang="en-US">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" href="/favicon.svg"/>
    <meta name="viewport" content="width=device-width" />
    <title>Eitrous's Blog</title>
  </head>

  <body>
    <Header />
    <main>
      <section class="hero">
        <h1>Thoughts on Dev, Writing, and Zen.</h1>
        <p>Collection of fragments of me.</p>
      </section>
      <section class="content">
        <div>
          <h2>LATEST POSTS</h2>
          <ul>
            {
              posts.map((post) => (
                <li>
                  <time datetime={post.data.pubDate.toISOString()}>
                    {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                    {post.data.type && ` · ${post.data.type.toUpperCase()}`}
                  </time>
                  <div class="essay-title">
                    <a href={`/blog/${post.id}/`}>{post.data.title}</a>
                  </div>
                  <p class="desc">{post.data.description}</p>
                </li>
              ))
            }
          </ul>
          <div style="text-align: center; margin-top: 32px;">
            <a href="/blog/">View All Posts</a>
          </div>
        </div>
        <aside>
          <section class="categories">
            <h2 class="section-title">CATEGORIES</h2>
            <ul>
            </ul>
          </section>
        </aside>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  html {
    min-height: 100vh;
  }

  body {
    font-family: Georgia, "Times New Roman", "Noto Serif SC", serif;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  main {
    width: min(1120px, calc(100% - 40px));
    margin: 20px auto;
    padding: 0;
    flex: 1;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  a:hover {
    color: #666;
  }

  .hero {
    padding: 96px 0;
    border-bottom: 1px solid var(--border);
  }

  .hero h1 {
    max-width: 820px;
    font-size: clamp(48px, 8vw, 96px);
    line-height: 1;
    font-weight: normal;
    letter-spacing: -0.04em;
    margin: 0;
  }

  .hero p {
    max-width: 520px;
    margin-top: 32px;
    font-size: 18px;
    color: #333;
    line-height: 1.7;
  }

  .content {
    margin-top: 48px;
    margin-bottom: 48px;
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 64px;
  }

  h2 {
    font-size: 0.8rem;
    font-weight: normal;
    letter-spacing: 0.04em;
    margin-bottom: 0px;
  }

  ul {
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
  }

  li {
    padding: 24px 0;
  }

  li {
    border-bottom: 1px solid var(--border);
  }

  time {
    font-size: 0.8rem;
    display: block;
    color: #777;
  }

  .essay-title {
    margin-top: 16px;
    margin-bottom: 16px;
  }

  .desc {
    color: #333;
  }

  .essay-title > a {
    font-size: 2rem;
    font-weight: normal;
    color: inherit;
    text-decoration: none;
  }

  .essay-title > a:hover {
    color: #666;
  }

  aside {
    border-left: 1px solid var(--border);
    padding-left: 32px;
  }

  @media (max-width: 768px) {
    .content {
      grid-template-columns: 1fr;
    }

    aside {
      border-left: none;
      padding-left: 0;
      margin-top: 48px;
    }
  }
</style>

---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
import "katex/dist/katex.min.css";

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
  categories?: string[];
  headings: { depth: number; slug: string; text: string }[];
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  tags = [],
  categories = [],
  headings = [],
} = Astro.props;
---

<!doctype html>
<html lang="en-US">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href="/favicon.svg"/>
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>

  <body>
    <Header />
    <main>
      <header>
        <h1>{title}</h1>

        <div class="meta-time">
          <span>
            Posted on
            <time datetime={pubDate.toISOString()}>
              {
                pubDate.toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "long",
                  day: "numeric",
                })
              }
            </time>
          </span>

          {
            updatedDate && (
              <span>
                Updated on
                <time datetime={updatedDate.toISOString()}>
                  {updatedDate.toLocaleDateString("en-US", {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                  })}
                </time>
              </span>
            )
          }
        </div>

        <div class="categories">
          {categories.map((category) => <span>In {category}</span>)}
        </div>

        <div class="tags">
          Tags:
          {tags.map((tag) => <span>#{tag}</span>)}
        </div>
      </header>
      <article>
        <aside class="toc">
          <p>Contents</p>
          <div>
          {
            headings.map((heading) => (
              <a
                href={`#${heading.slug}`}
                style={`margin-left: ${(heading.depth - 2) * 12}px`}
              >
                {heading.text}
              </a>
            ))
          }
          </div>
        </aside>
        <div class="content">
          <slot />
        </div>
      </article>
    </main>
    <Footer />
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            // 当某个标题进入视口且在设定范围内时
            if (entry.isIntersecting) {
              const id = entry.target.id;
              
              // 移除所有目录项的激活状态
              document.querySelectorAll('.toc a').forEach((link) => {
                link.classList.remove('active');
              });

              // 给当前对应的目录项加上激活状态
              const activeLink = document.querySelector(`.toc a[href="#${id}"]`);
              if (activeLink) {
                activeLink.classList.add('active');

                activeLink.scrollIntoView({
                  behavior: 'smooth',
                  block: 'nearest',
                });
              }
            }
          });
        },
        {
          // 这里的 rootMargin 控制触发高亮的范围 
          // "-100px 0px -60% 0px" 代表：当标题滚动到页面顶部往下的高亮区域时触发
          rootMargin: "-100px 0px -60% 0px" 
        }
      );

      // 获取正文里所有的标题元素并开始监听
      const headings = document.querySelectorAll('.content h1, .content h2, .content h3, .content h4, .content h5, .content h6');
      headings.forEach((heading) => {
        observer.observe(heading);
      });
    </script>
  </body>
</html>

<style>
  body {
    font-family: "Noto Serif CJK", Georgia, "Times New Roman", serif;
  }

  main {
    margin: 0 auto;
    padding: 40px 0 80px;
  }

  nav {
    display: flex;
    gap: 20px;
    margin-bottom: 64px;
  }

  header {
    max-width: 820px;
    margin: 0 auto;
  }

  article {
    width: min(1120px, calc(100% - 40px));
    margin: 0 auto;
    padding: 20px 0 80px;
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 80px;
    align-items: start;
  }

  header h1 {
    font-size: 2.4rem;
    font-weight: normal;
    line-height: 1.2;
  }

  .toc {
    position: sticky;
    top: 40px;
    padding-top: 30px;
    font-size: 14px;
  }

  .toc div {
    max-height: calc(100vh - 180px);
    overflow-y: auto;  
  }

  .toc div::-webkit-scrollbar {
    display: none;
  }

  .toc div {
    scrollbar-width: none;
  }

  .toc p {
    margin-bottom: 18px;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--muted);
  }

  .toc a {
    display: block;
    margin-bottom: 14px;
    line-height: 1.4;
    color: var(--muted);
    text-decoration: none;
  }

  .toc a:hover {
    color: var(--text);
  }

  .toc a:hover,
  .toc a.active {
    color: var(--text); 
  }

  .meta-time {
    display: flex;
    gap: 24px;
  }

  .categories {
    display: flex;
    gap: 10px;
    margin-top: 16px;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 16px;
  }

  .content {
    margin-top: 0;
    font-size: 1.125rem;
    line-height: 1.8;
  }

  .content img {
    display: block;
    max-width: 100%;
    height: auto;
    margin: 32px auto;
    border-radius: 8px;
  }

  .content pre {
    overflow-x: auto;
    padding: 18px;
    border-radius: 8px;
  }

  .content a {
    text-underline-offset: 4px;
  }

  .content :global(.katex-display) {
    overflow-x: auto;
    overflow-y: hidden;
    padding: 0.25rem 0;
  }

  @media (max-width: 768px) {
    article {
      grid-template-columns: 1fr;
    }

    .toc {
      display: none;
    }

    .content {
      margin-right: 0;
    }
</style>
